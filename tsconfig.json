{
  "compilerOptions": {
    /* Core Settings */
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler", // <-- Resolve o problema das extensões
    "lib": ["DOM", "ESNext"],
    "rootDir": "./src",
    "outDir": "./dist",

    /* Strictness - Fundamental para um Banco de Dados */
    "strict": true,
    "noUncheckedIndexedAccess": true, 
    "exactOptionalPropertyTypes": true,
    
    /* Clean Code */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Interop & Modernity */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false, // Alterado para false para evitar conflitos com importações de tipos
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowImportingTsExtensions": false, // Mantemos falso para usar caminhos sem extensão

    /* Output */
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
